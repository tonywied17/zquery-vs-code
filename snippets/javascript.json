    "description": "Left-to-right function composition."
  },
  "zQuery Once": {
    "prefix": "zq-once",
    "body": [
      "const ${1:load} = $.once(async () => {",
      "\t${2:return await fetch('/config.json');}",
      "});"
    ],
    "description": "Function that executes only once and caches the result."
  },
  "zQuery Sleep": {
    "prefix": "zq-sleep",
    "body": [
      "await $.sleep(${1:1000});"
    ],
    "description": "Await a Promise that resolves after ms milliseconds."
  },
  "zQuery UUID": {
    "prefix": "zq-uuid",
    "body": [
      "const ${1:id} = $.uuid();"
    ],
    "description": "Generate a UUID v4 string."
  },
  "zQuery Escape HTML": {

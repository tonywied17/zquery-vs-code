{

  "_comment_selectors": "──── Selectors & DOM ────",

  "zQuery Select ($)": {
    "prefix": "zq-select",
    "body": [
      "const ${1:el} = $('${2:selector}');"
    ],
    "description": "Chainable selector — returns a ZQueryCollection via querySelectorAll."
  },
  "zQuery Select Scoped": {
    "prefix": "zq-select-scoped",
    "body": [
      "const ${1:el} = $('${2:selector}', '${3:#parent}');"
    ],
    "description": "Scoped chainable selector — ZQueryCollection scoped to a parent element."
  },
  "zQuery Select by ID": {
    "prefix": "zq-id",
    "body": [
      "const ${1:el} = $.id('${2:elementId}');"
    ],
    "description": "Select element by ID — document.getElementById."
  },
  "zQuery Select by Class": {
    "prefix": "zq-class",
    "body": [
      "const ${1:el} = $.class('${2:className}');"
    ],
    "description": "Select first element with class — querySelector('.name')."
  },
  "zQuery Select All by Class": {
    "prefix": "zq-classes",
    "body": [
      "const ${1:elements} = $.classes('${2:className}');"
    ],
    "description": "Select all elements with class — ZQueryCollection."
  },
  "zQuery Select by Tag": {
    "prefix": "zq-bytag",
    "body": [
      "const ${1:elements} = $.tag('${2:div}');"
    ],
    "description": "Select all elements by tag name — ZQueryCollection."
  },
  "zQuery Select by Name": {
    "prefix": "zq-name",
    "body": [
      "const ${1:elements} = $.name('${2:fieldName}');"
    ],
    "description": "Select elements by name attribute — ZQueryCollection."
  },
  "zQuery Children": {
    "prefix": "zq-children",
    "body": [
      "const ${1:items} = $.children('${2:parentId}');"
    ],
    "description": "Direct children of #parentId as ZQueryCollection."
  },
  "zQuery Collection Chain": {
    "prefix": "zq-all",
    "body": [
      "$.all('${1:.selector}')${2:.each((i, el) => {",
      "\t${3}",
      "});}$0"
    ],
    "description": "Query all matching elements and chain a method. Alias for $() — both return ZQueryCollection."
  },
  "zQuery Create Element": {
    "prefix": "zq-create",
    "body": [
      "const ${1:el} = $.create('${2:div}', {",
      "\tclass: '${3}',",
      "\t${4}",
      "}, ${5:'content'});"
    ],
    "description": "Create a DOM element with attributes → ZQueryCollection (chainable)."
  },
  "zQuery DOM Ready ($)": {
    "prefix": "zq-domready",
    "body": [
      "$(() => {",
      "\t${1}",
      "});"
    ],
    "description": "DOM-ready callback shorthand using $(fn)."
  },
  "zQuery Ready": {
    "prefix": "zq-ready",
    "body": [
      "$.ready(() => {",
      "\t${1}",
      "});"
    ],
    "description": "DOM ready callback (DOMContentLoaded)."
  },

  "_comment_collection": "──── Collection Operations ────",

  "zQuery Collection .on()": {
    "prefix": "zq-all-on",
    "body": [
      "$.all('${1:.selector}').on('${2:click}', (e) => {",
      "\t${3}",
      "});"
    ],
    "description": "Attach event handler to all matching elements."
  },
  "zQuery Collection .addClass()": {
    "prefix": "zq-all-addclass",
    "body": [
      "$.all('${1:.selector}').addClass('${2:className}');"
    ],
    "description": "Add a class to all matching elements."
  },
  "zQuery Collection .css()": {
    "prefix": "zq-all-css",
    "body": [
      "$.all('${1:.selector}').css({ ${2:opacity}: '${3:0}' });"
    ],
    "description": "Set inline styles on all matching elements."
  },
  "zQuery Collection .animate()": {
    "prefix": "zq-all-animate",
    "body": [
      "await $.all('${1:.selector}').animate({ ${2:opacity: '0', transform: 'translateY(-10px)'} }, ${3:300});"
    ],
    "description": "Animate CSS properties on matching elements (returns Promise)."
  },
  "zQuery Collection .fadeIn()": {
    "prefix": "zq-all-fadein",
    "body": [
      "await $.all('${1:.selector}').fadeIn(${2:300});"
    ],
    "description": "Fade in matching elements (opacity 0→1, returns Promise)."
  },
  "zQuery Collection .fadeOut()": {
    "prefix": "zq-all-fadeout",
    "body": [
      "await $.all('${1:.selector}').fadeOut(${2:300});"
    ],
    "description": "Fade out matching elements (opacity 1→0, returns Promise)."
  },
  "zQuery Collection .slideToggle()": {
    "prefix": "zq-all-slidetoggle",
    "body": [
      "$.all('${1:.selector}').slideToggle(${2:300});"
    ],
    "description": "Toggle height with slide animation on matching elements."
  },
  "zQuery Form Serialize": {
    "prefix": "zq-serialize",
    "body": [
      "const ${1:data} = $.all('${2:#myForm}').serializeObject();"
    ],
    "description": "Serialize form data as key/value object."
  },
  "zQuery Plugin ($.fn)": {
    "prefix": "zq-plugin",
    "body": [
      "$.fn.${1:methodName} = function(${2}) {",
      "\treturn this.each((i, el) => {",
      "\t\t${3}",
      "\t});",
      "};"
    ],
    "description": "Extend ZQueryCollection with a custom plugin method."
  },

  "_comment_events": "──── Events ────",

  "zQuery Event Delegation": {
    "prefix": "zq-on",
    "body": [
      "$.on('${1:click}', '${2:.selector}', function(e) {",
      "\t${3}",
      "});"
    ],
    "description": "Global delegated event listener on document (3-arg form)."
  },
  "zQuery Direct Event Listener": {
    "prefix": "zq-on-direct",
    "body": [
      "$.on('${1:keydown}', (e) => {",
      "\t${2}",
      "});"
    ],
    "description": "Direct global event listener on document (2-arg form — keydown, resize, etc.)."
  },
  "zQuery Remove Global Listener": {
    "prefix": "zq-off",
    "body": [
      "$.off('${1:event}', ${2:handler});"
    ],
    "description": "Remove a direct global event listener added with $.on(event, handler)."
  },

  "_comment_reactive": "──── Reactive ────",

  "zQuery Signal": {
    "prefix": "zq-signal",
    "body": [
      "const ${1:count} = $.signal(${2:0});"
    ],
    "description": "Create a reactive signal."
  },
  "zQuery Signal Subscribe": {
    "prefix": "zq-signal-sub",
    "body": [
      "const unsub = ${1:signal}.subscribe(() => {",
      "\t${2:console.log(${1}.value);}",
      "});"
    ],
    "description": "Manually subscribe to a signal's changes."
  },
  "zQuery Computed": {
    "prefix": "zq-computed",
    "body": [
      "const ${1:derived} = $.computed(() => ${2:count.value * 2});"
    ],
    "description": "Create a computed (derived) signal."
  },
  "zQuery Effect": {
    "prefix": "zq-effect",
    "body": [
      "const dispose = $.effect(() => {",
      "\t${1:// runs when signals change}",
      "});"
    ],
    "description": "Create a reactive effect with auto-tracking."
  },
  "zQuery Reactive": {
    "prefix": "zq-reactive",
    "body": [
      "const ${1:state} = $.reactive({ ${2} }, (key, value, old) => {",
      "\t${3:// property changed}",
      "});"
    ],
    "description": "Create a deep reactive proxy."
  },

  "_comment_components": "──── Components ────",

  "zQuery Component": {
    "prefix": "zq-component",
    "body": [
      "$.component('${1:my-component}', {",
      "\tstate: () => ({",
      "\t\t${2:key}: ${3:value},",
      "\t}),",
      "",
      "\tinit() {",
      "\t\t${4:// called before first render}",
      "\t},",
      "",
      "\tmounted() {",
      "\t\t${5:// called after first render}",
      "\t},",
      "",
      "\t${6:handleClick}(e) {",
      "\t\t${7:// method}",
      "\t},",
      "",
      "\trender() {",
      "\t\treturn `",
      "\t\t\t<div>",
      "\t\t\t\t${8:<!-- template -->}",
      "\t\t\t</div>",
      "\t\t`;",
      "\t},",
      "});"
    ],
    "description": "Full zQuery component definition with state, lifecycle hooks, methods, and render."
  },
  "zQuery Component (Simple)": {
    "prefix": "zq-component-simple",
    "body": [
      "$.component('${1:my-component}', {",
      "\tstate: () => ({ ${2} }),",
      "",
      "\trender() {",
      "\t\treturn `${3}`;",
      "\t},",
      "});"
    ],
    "description": "Minimal zQuery component with state and render."
  },
  "zQuery Component (Pages)": {
    "prefix": "zq-component-pages",
    "body": [
      "$.component('${1:docs-page}', {",
      "\tpages: {",
      "\t\tdir:     '${2:pages}',",
      "\t\tparam:   '${3:section}',",
      "\t\tdefault: '${4:getting-started}',",
      "\t\titems: [",
      "\t\t\t'${4}',",
      "\t\t\t${5:'another-page'},",
      "\t\t],",
      "\t},",
      "",
      "\tstyleUrl: '${6:styles.css}',",
      "",
      "\trender() {",
      "\t\treturn `",
      "\t\t\t<nav>",
      "\t\t\t\t\\${this.pages.map(p => `",
      "\t\t\t\t\t<a class=\"\\${this.activePage === p.id ? 'active' : ''}\"",
      "\t\t\t\t\t   z-link=\"/${1}/\\${p.id}\">\\${p.label}</a>",
      "\t\t\t\t`).join('')}",
      "\t\t\t</nav>",
      "\t\t\t<main>\\${this.templates[this.activePage] || ''}</main>",
      "\t\t`;",
      "\t},",
      "});"
    ],
    "description": "zQuery component with pages config — lazy-loaded multi-page sections with route-driven switching."
  },
  "zQuery Component (External Template)": {
    "prefix": "zq-component-template",
    "body": [
      "$.component('${1:my-component}', {",
      "\tstate: () => ({ ${2} }),",
      "\ttemplateUrl: '${3:template.html}',",
      "\tstyleUrl: '${4:styles.css}',",
      "});"
    ],
    "description": "zQuery component with external template and stylesheet."
  },
  "zQuery Mount": {
    "prefix": "zq-mount",
    "body": [
      "const ${1:instance} = $.mount('${2:#app}', '${3:component-name}'${4:, { ${5} }});"
    ],
    "description": "Mount a registered component."
  },
  "zQuery Mount All": {
    "prefix": "zq-mountall",
    "body": [
      "$.mountAll(${1});"
    ],
    "description": "Auto-mount all registered component tags found in the DOM."
  },
  "zQuery Get Instance": {
    "prefix": "zq-getinstance",
    "body": [
      "const ${1:instance} = $.getInstance('${2:#target}');"
    ],
    "description": "Get the component instance mounted at a target element."
  },
  "zQuery Destroy Component": {
    "prefix": "zq-destroy",
    "body": [
      "$.destroy('${1:#target}');"
    ],
    "description": "Destroy the component mounted at the given target."
  },
  "zQuery List Components": {
    "prefix": "zq-components",
    "body": [
      "console.log($.components());"
    ],
    "description": "List all registered component definitions (debugging)."
  },
  "zQuery Component setState": {
    "prefix": "zq-setstate",
    "body": [
      "this.setState({ ${1:key}: ${2:value} });"
    ],
    "description": "Merge partial state into component (triggers re-render)."
  },
  "zQuery Component Emit": {
    "prefix": "zq-emit",
    "body": [
      "this.emit('${1:eventName}', { ${2} });"
    ],
    "description": "Dispatch a bubbling CustomEvent from the component root."
  },

  "_comment_router": "──── Router ────",

  "zQuery Router": {
    "prefix": "zq-router",
    "body": [
      "const router = $.router({",
      "\tel: '${1:#app}',",
      "\troutes: [",
      "\t\t{ path: '/', component: '${2:home-page}' },",
      "\t\t{ path: '/${3:about}', component: '${4:about-page}' },",
      "\t\t${5}",
      "\t],",
      "\tfallback: '${6:not-found}',",
      "});"
    ],
    "description": "zQuery SPA router setup with routes and fallback."
  },
  "zQuery Router (Hash Mode)": {
    "prefix": "zq-router-hash",
    "body": [
      "const router = $.router({",
      "\tel: '${1:#app}',",
      "\tmode: 'hash',",
      "\troutes: [",
      "\t\t{ path: '/', component: '${2:home-page}' },",
      "\t\t${3}",
      "\t],",
      "\tfallback: '${4:not-found}',",
      "});"
    ],
    "description": "zQuery SPA router in hash mode (#/path)."
  },
  "zQuery Route (Lazy)": {
    "prefix": "zq-route-lazy",
    "body": [
      "{ path: '/${1:page}', load: () => import('./${2:pages/$1.js}'), component: '${3:$1-page}' },"
    ],
    "description": "Lazy-loaded route definition."
  },
  "zQuery Route (Fallback)": {
    "prefix": "zq-route-fallback",
    "body": [
      "{ path: '/${1:docs}/:${2:section}', component: '${3:docs-page}', fallback: '/${1}' },"
    ],
    "description": "Route with fallback path (used with pages config)."
  },
  "zQuery Router Guard": {
    "prefix": "zq-guard",
    "body": [
      "router.beforeEach(async (to, from) => {",
      "\t${1:// return false to cancel, or '/path' to redirect}",
      "});"
    ],
    "description": "Add a router navigation guard."
  },
  "zQuery Router onChange": {
    "prefix": "zq-route-change",
    "body": [
      "const unsub = router.onChange((to, from) => {",
      "\t${1:console.log('Navigated to', to.path);}",
      "});"
    ],
    "description": "Subscribe to route changes."
  },
  "zQuery Get Router": {
    "prefix": "zq-getrouter",
    "body": [
      "const ${1:router} = $.getRouter();"
    ],
    "description": "Get the currently active router instance."
  },
  "zQuery Router Navigate": {
    "prefix": "zq-navigate",
    "body": [
      "${1:router}.navigate('${2:/path}');"
    ],
    "description": "Navigate to a path using the router."
  },
  "zQuery Router Replace": {
    "prefix": "zq-replace",
    "body": [
      "${1:router}.replace('${2:/path}');"
    ],
    "description": "Replace the current route (no new history entry)."
  },
  "zQuery Route (Dynamic Add)": {
    "prefix": "zq-route-add",
    "body": [
      "${1:router}.add({ path: '${2:/page}', component: '${3:page-component}' });"
    ],
    "description": "Add a route dynamically at runtime."
  },

  "_comment_store": "──── Store ────",

  "zQuery Store": {
    "prefix": "zq-store",
    "body": [
      "const ${1:store} = $.store({",
      "\tstate: {",
      "\t\t${2:items}: ${3:[]},",
      "\t},",
      "\tactions: {",
      "\t\t${4:addItem}(state, ${5:item}) {",
      "\t\t\t${6:state.$2 = [...(state.$2.__raw || state.$2), $5];}",
      "\t\t},",
      "\t},",
      "\tgetters: {",
      "\t\t${7:count}: (state) => state.${2}.length,",
      "\t},",
      "});"
    ],
    "description": "zQuery reactive store with state, actions, and getters."
  },
  "zQuery Named Store": {
    "prefix": "zq-store-named",
    "body": [
      "const ${1:store} = $.store('${2:storeName}', {",
      "\tstate: { ${3} },",
      "\tactions: {",
      "\t\t${4}",
      "\t},",
      "});"
    ],
    "description": "Named zQuery store ($.getStore('name') to retrieve)."
  },
  "zQuery Get Store": {
    "prefix": "zq-getstore",
    "body": [
      "const ${1:store} = $.getStore(${2:'default'});"
    ],
    "description": "Retrieve a previously created store by name."
  },
  "zQuery Store Subscribe": {
    "prefix": "zq-store-sub",
    "body": [
      "const unsub = ${1:store}.subscribe('${2:key}', (value, old) => {",
      "\t${3}",
      "});"
    ],
    "description": "Subscribe to a specific store state key."
  },
  "zQuery Store Dispatch": {
    "prefix": "zq-dispatch",
    "body": [
      "${1:store}.dispatch('${2:actionName}'${3:, ${4:payload}});"
    ],
    "description": "Dispatch a named store action."
  },
  "zQuery Store Snapshot": {
    "prefix": "zq-snapshot",
    "body": [
      "const ${1:snapshot} = ${2:store}.snapshot();"
    ],
    "description": "Deep clone of current store state."
  },
  "zQuery Store Middleware": {
    "prefix": "zq-store-use",
    "body": [
      "${1:store}.use((action, args, state) => {",
      "\t${2:console.log(action, args);}",
      "\t// return false to block the action",
      "});"
    ],
    "description": "Add store middleware."
  },

  "_comment_http": "──── HTTP Client ────",

  "zQuery HTTP Configure": {
    "prefix": "zq-http-config",
    "body": [
      "$.http.configure({",
      "\tbaseURL: '${1:https://api.example.com}',",
      "\theaders: { ${2:Authorization: 'Bearer ' + token} },",
      "\ttimeout: ${3:10000},",
      "});"
    ],
    "description": "Configure zQuery HTTP client defaults."
  },
  "zQuery HTTP GET": {
    "prefix": "zq-get",
    "body": [
      "const { data } = await $.get('${1:/api/endpoint}'${2:, { ${3} }});"
    ],
    "description": "HTTP GET request with destructured response."
  },
  "zQuery HTTP POST": {
    "prefix": "zq-post",
    "body": [
      "const { data } = await $.post('${1:/api/endpoint}', {",
      "\t${2}",
      "});"
    ],
    "description": "HTTP POST request with JSON body."
  },
  "zQuery HTTP PUT": {
    "prefix": "zq-put",
    "body": [
      "const { data } = await $.put('${1:/api/endpoint}', {",
      "\t${2}",
      "});"
    ],
    "description": "HTTP PUT request with JSON body."
  },
  "zQuery HTTP PATCH": {
    "prefix": "zq-patch",
    "body": [
      "const { data } = await $.patch('${1:/api/endpoint}', {",
      "\t${2}",
      "});"
    ],
    "description": "HTTP PATCH request with JSON body."
  },
  "zQuery HTTP DELETE": {
    "prefix": "zq-delete",
    "body": [
      "await $.delete('${1:/api/endpoint}');"
    ],
    "description": "HTTP DELETE request."
  },
  "zQuery HTTP (try/catch)": {
    "prefix": "zq-http-try",
    "body": [
      "try {",
      "\tconst { data } = await $.${1|get,post,put,patch,delete|}('${2:/api/endpoint}'${3});",
      "\t${4:console.log(data);}",
      "} catch (err) {",
      "\tconsole.error(err.response?.status, err.response?.data);",
      "}"
    ],
    "description": "HTTP request with error handling."
  },
  "zQuery HTTP Abort": {
    "prefix": "zq-http-abort",
    "body": [
      "const controller = $.http.createAbort();",
      "$.get('${1:/api/endpoint}', null, { signal: controller.signal });",
      "${2:controller.abort(); // cancel the request}"
    ],
    "description": "Create an AbortController for request cancellation."
  },
  "zQuery Interceptor (Request)": {
    "prefix": "zq-interceptor-req",
    "body": [
      "$.http.onRequest(async (opts, url) => {",
      "\t${1:opts.headers['Authorization'] = 'Bearer ' + getToken();}",
      "});"
    ],
    "description": "Add an HTTP request interceptor."
  },
  "zQuery Interceptor (Response)": {
    "prefix": "zq-interceptor-res",
    "body": [
      "$.http.onResponse(async (result) => {",
      "\t${1:if (result.status === 401) { /* handle */ \\}}",
      "});"
    ],
    "description": "Add an HTTP response interceptor."
  },

  "_comment_utilities": "──── Utilities ────",

  "zQuery Debounce": {
    "prefix": "zq-debounce",
    "body": [
      "const ${1:handler} = $.debounce((${2}) => {",
      "\t${3}",
      "}, ${4:300});"
    ],
    "description": "Create a debounced function."
  },
  "zQuery Throttle": {
    "prefix": "zq-throttle",
    "body": [
      "const ${1:handler} = $.throttle((${2}) => {",
      "\t${3}",
      "}, ${4:100});"
    ],
    "description": "Create a throttled function."
  },
  "zQuery Pipe": {
    "prefix": "zq-pipe",
    "body": [
      "const ${1:process} = $.pipe(",
      "\t(val) => ${2:val.trim()},",
      "\t(val) => ${3:val.toLowerCase()},",
      ");"

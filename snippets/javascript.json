  "zQuery Safe HTML Template": {
    "prefix": "zq-html-safe",
    "body": [
      "$.html`${1:<div>\\${${2:unsafeVar}}</div>}`"
    ],
    "description": "Tagged template literal that auto-escapes interpolated values."
  },
  "zQuery Trust HTML": {
    "prefix": "zq-trust",
    "body": [
      "$.trust(${1:htmlString})"
    ],
    "description": "Mark an HTML string as trusted (won't be escaped inside $.html)."

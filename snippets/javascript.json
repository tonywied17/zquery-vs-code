  "zQuery camelCase": {
    "prefix": "zq-camelcase",
    "body": [
      "$.camelCase('${1:my-string}')"
    ],
    "description": "Convert kebab-case to camelCase."
  },
  "zQuery kebabCase": {
    "prefix": "zq-kebabcase",
    "body": [
      "$.kebabCase('${1:myString}')"
    ],
    "description": "Convert camelCase to kebab-case."
  },
  "zQuery Deep Clone": {
    "prefix": "zq-deepclone",
    "body": [
      "const ${1:clone} = $.deepClone(${2:obj});"
    ],
    "description": "Deep clone an object using structuredClone (JSON fallback)."
  },
  "zQuery Deep Merge": {
    "prefix": "zq-deepmerge",
    "body": [
      "const ${1:merged} = $.deepMerge({}, ${2:defaults}, ${3:overrides});"

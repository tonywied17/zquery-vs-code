{

  "_comment_directives": "──── z-* Directives ────",

  "z-if Conditional": {
    "prefix": "z-if",
    "body": [
      "z-if=\"${1:condition}\""
    ],
    "description": "zQuery conditional rendering — removes element from DOM when falsy."
  },
  "z-if / z-else Block": {
    "prefix": "z-if-else",
    "body": [
      "<${1:div} z-if=\"${2:condition}\">",
      "\t$3",
      "</${1}>",
      "<${1} z-else>",
      "\t$4",
      "</${1}>"
    ],
    "description": "zQuery z-if / z-else conditional block."
  },
  "z-if / z-else-if / z-else Block": {
    "prefix": "z-if-elseif-else",
    "body": [
      "<${1:div} z-if=\"${2:condition1}\">",
      "\t$5",
      "</${1}>",
      "<${1} z-else-if=\"${3:condition2}\">",
      "\t$6",
      "</${1}>",
      "<${1} z-else>",
      "\t$7",
      "</${1}>"
    ],
    "description": "zQuery z-if / z-else-if / z-else conditional chain."
  },
  "z-else-if Attribute": {
    "prefix": "z-else-if",
    "body": [
      "z-else-if=\"${1:condition}\""
    ],
    "description": "zQuery else-if branch — must follow z-if or z-else-if."
  },
  "z-else Attribute": {
    "prefix": "z-else",
    "body": [
      "z-else"
    ],
    "description": "zQuery else branch — must follow z-if or z-else-if."
  },
  "z-for List Rendering": {
    "prefix": "z-for",
    "body": [
      "<${1:li} z-for=\"${2:item} in ${3:items}\">",
      "\t{{${2}.${4:name}}}",
      "</${1}>"
    ],
    "description": "zQuery list rendering — repeats element for each item. $index is auto-provided."
  },
  "z-for with Index": {
    "prefix": "z-for-index",
    "body": [
      "<${1:li} z-for=\"${2:item} in ${3:items}\">",
      "\t{{\\$index}}: {{${2}.${4:name}}}",
      "</${1}>"
    ],
    "description": "zQuery list rendering with $index."
  },
  "z-show Toggle": {
    "prefix": "z-show",
    "body": [
      "z-show=\"${1:condition}\""
    ],
    "description": "zQuery visibility toggle — sets display:none when falsy (element stays in DOM)."
  },
  "z-bind Dynamic Attribute": {
    "prefix": "z-bind",
    "body": [
      "z-bind:${1:attr}=\"${2:expression}\""
    ],
    "description": "zQuery dynamic attribute binding. Shorthand: :attr=\"expr\""
  },
  ":attr Shorthand Binding": {
    "prefix": ":bind",
    "body": [
      ":${1:attr}=\"${2:expression}\""
    ],
    "description": "zQuery attribute binding shorthand (:href, :src, :disabled, etc.)"
  },
  "z-class Dynamic Classes": {
    "prefix": "z-class",
    "body": [
      "z-class=\"{${1:className}: ${2:condition}}\""
    ],
    "description": "zQuery dynamic CSS class binding with object syntax."
  },
  "z-style Dynamic Styles": {
    "prefix": "z-style",
    "body": [
      "z-style=\"{${1:property}: ${2:value}}\""
    ],
    "description": "zQuery dynamic inline style binding with object syntax."
  },
  "z-text Content": {
    "prefix": "z-text",
    "body": [
      "z-text=\"${1:stateKey}\""
    ],
    "description": "zQuery text content binding — sets textContent (auto-escaped)."
  },
  "z-html Content": {
    "prefix": "z-html",
    "body": [
      "z-html=\"${1:stateKey}\""
    ],
    "description": "zQuery HTML content binding — sets innerHTML (use with trusted content only)."
  },
  "z-model Attribute": {
    "prefix": "z-model",
    "body": [
      "z-model=\"${1:stateKey}\""
    ],
    "description": "zQuery two-way binding between a form element and component state."
  },
  "z-model (Nested)": {
    "prefix": "z-model-nested",
    "body": [
      "z-model=\"${1:parent}.${2:child}\""
    ],
    "description": "zQuery two-way binding with dot-notation for nested state."
  },
  "z-model + Modifiers": {
    "prefix": "z-model-mods",
    "body": [
      "z-model=\"${1:stateKey}\" ${2|z-lazy,z-trim,z-number|}"
    ],
    "description": "zQuery z-model with a modifier (z-lazy, z-trim, z-number)."
  },
  "z-model (Checkbox)": {
    "prefix": "z-model-checkbox",
    "body": [
      "<label>",
      "\t<input z-model=\"${1:checked}\" type=\"checkbox\">",
      "\t${2:Label}",
      "</label>"
    ],
    "description": "zQuery z-model checkbox with boolean binding."
  },
  "z-model (Radio Group)": {
    "prefix": "z-model-radio",
    "body": [
      "<label><input z-model=\"${1:selected}\" type=\"radio\" value=\"${2:option1}\"> ${3:Option 1}</label>",
      "<label><input z-model=\"${1}\" type=\"radio\" value=\"${4:option2}\"> ${5:Option 2}</label>"
    ],
    "description": "zQuery z-model radio button group."
  },
  "z-model (Number Input)": {
    "prefix": "z-model-number",
    "body": [
      "<input z-model=\"${1:age}\" type=\"number\" min=\"${2:0}\" ${3:max=\"${4:100}\"}>"
    ],
    "description": "zQuery z-model with number input (reads as Number automatically)."
  },
  "z-model (Select Dropdown)": {
    "prefix": "z-model-select",
    "body": [
      "<select z-model=\"${1:selected}\">",
      "\t<option value=\"\">${2:-- Choose --}</option>",
      "\t<option value=\"${3:val1}\">${4:Label 1}</option>",
      "\t<option value=\"${5:val2}\">${6:Label 2}</option>",
      "</select>"
    ],
    "description": "zQuery z-model select dropdown."
  },
  "z-model (Textarea)": {
    "prefix": "z-model-textarea",
    "body": [
      "<textarea z-model=\"${1:content}\" ${2:z-lazy} placeholder=\"${3:Enter text...}\"></textarea>"
    ],
    "description": "zQuery z-model textarea with optional lazy modifier."
  },
  "z-ref Attribute": {
    "prefix": "z-ref",
    "body": [
      "z-ref=\"${1:refName}\""
    ],
    "description": "zQuery element reference — access via this.refs.refName in component code."
  },
  "z-on: Event Binding": {
    "prefix": "z-on",
    "body": [
      "z-on:${1:event}=\"${2:methodName}\""
    ],
    "description": "zQuery event binding (z-on:event form). Identical to @event shorthand."
  },
  "z-on: with Modifier": {
    "prefix": "z-on-mod",
    "body": [
      "z-on:${1:click}.${2|prevent,stop,once,self,capture,passive|}=\"${3:methodName}\""
    ],
    "description": "zQuery event binding with modifier."
  },
  "z-cloak Attribute": {
    "prefix": "z-cloak",
    "body": [
      "z-cloak"
    ],
    "description": "zQuery hide-until-rendered — prevents flash of unprocessed template."
  },
  "z-pre Attribute": {
    "prefix": "z-pre",
    "body": [
      "z-pre"
    ],
    "description": "zQuery skip directive processing for this element and its children."
  },
  "z-link (Router)": {
    "prefix": "z-link",
    "body": [
      "<a z-link=\"${1:/path}\">${2:Link Text}</a>"
    ],
    "description": "zQuery SPA navigation link (intercepted by router, no reload)."
  },
  "z-link with params": {
    "prefix": "z-link-params",
    "body": [
      "<a z-link=\"${1:/user/:id}\" z-link-params='{\"${2:id}\": \"${3:value}\"}'>${4:Link Text}</a>"
    ],
    "description": "zQuery z-link with dynamic :param interpolation via z-link-params."
  },

  "_comment_events": "──── @ Event Bindings ────",

  "@click Handler": {
    "prefix": "@click",
    "body": [
      "@click=\"${1:methodName}\""
    ],
    "description": "zQuery click event binding to a component method."
  },
  "@click with Arguments": {
    "prefix": "@click-args",
    "body": [
      "@click=\"${1:methodName}(${2:args})\""
    ],
    "description": "zQuery click event with method arguments."
  },
  "@click.prevent": {
    "prefix": "@click-prevent",
    "body": [
      "@click.prevent=\"${1:methodName}\""
    ],
    "description": "zQuery click with preventDefault."
  },
  "@submit.prevent Handler": {
    "prefix": "@submit",
    "body": [
      "@submit.prevent=\"${1:handleSubmit}\""
    ],
    "description": "zQuery form submit binding with preventDefault."
  },
  "@input Handler": {
    "prefix": "@input",
    "body": [
      "@input=\"${1:handleInput}\""
    ],
    "description": "zQuery input event binding."
  },
  "@change Handler": {
    "prefix": "@change",
    "body": [
      "@change=\"${1:handleChange}\""
    ],
    "description": "zQuery change event binding."
  },
  "@keydown Handler": {
    "prefix": "@keydown",
    "body": [
      "@keydown=\"${1:handleKey}\""
    ],
    "description": "zQuery keydown event binding."
  },
  "@keyup Handler": {
    "prefix": "@keyup",
    "body": [
      "@keyup=\"${1:handleKey}\""
    ],
    "description": "zQuery keyup event binding."
  },
  "@event (Custom)": {
    "prefix": "@event",
    "body": [
      "@${1:event}=\"${2:methodName}\""
    ],
    "description": "zQuery custom event binding to a component method."
  },
  "@event.prevent.stop": {
    "prefix": "@event-prevent-stop",
    "body": [
      "@${1:click}.prevent.stop=\"${2:methodName}\""
    ],
    "description": "zQuery event binding with both preventDefault and stopPropagation."
  },
  "@event.once": {
    "prefix": "@event-once",
    "body": [
      "@${1:click}.once=\"${2:methodName}\""
    ],
    "description": "zQuery one-time event — handler fires once then auto-removes."
  },
  "@event.self": {
    "prefix": "@event-self",
    "body": [
      "@${1:click}.self=\"${2:methodName}\""
    ],
    "description": "zQuery self-only event — only fires when target is the element itself."
  },
  "@event.capture": {
    "prefix": "@event-capture",
    "body": [
      "@${1:click}.capture=\"${2:methodName}\""
    ],
    "description": "zQuery capture-phase event listener."
  },
  "@event.passive": {
    "prefix": "@event-passive",
    "body": [
      "@${1:scroll}.passive=\"${2:methodName}\""
    ],
    "description": "zQuery passive event listener for performance."
  },
  "@event.debounce": {
    "prefix": "@event-debounce",
    "body": [
      "@${1:input}.debounce.${2:300}=\"${3:methodName}\""
    ],
    "description": "zQuery debounced event — delays handler by specified ms."
  },
  "@event.throttle": {
    "prefix": "@event-throttle",
    "body": [
      "@${1:scroll}.throttle.${2:100}=\"${3:methodName}\""
    ],
    "description": "zQuery throttled event — fires at most once per specified ms."
  },

  "_comment_templates": "──── Component Templates ────",

  "zQuery Component Tag": {
    "prefix": "zq-tag",
    "body": [
      "<${1:my-component}${2: ${3:prop}=\"${4:value}\"}></${1}>"
    ],
    "description": "Custom element tag for a zQuery component."
  },
  "zQuery Component Embed": {
    "prefix": "zq-embed",
    "body": [
      "<${1:my-component} ${2:prop}=\"${3:value}\"></${1}>"
    ],
    "description": "Embed a registered zQuery component with props."
  },
  "zQuery Template Expression": {
    "prefix": "zq-expr",
    "body": [
      "{{${1:expression}}}"
    ],
    "description": "Template expression for external HTML templates ({{…}})."
  },
  "zQuery Conditional Rendering": {
    "prefix": "zq-if",
    "body": [
      "\\${${1:condition} ? `",
      "\t${2:<!-- shown when true -->}",
      "` : `",
      "\t${3:<!-- shown when false -->}",
      "`}"
    ],
    "description": "Ternary conditional rendering in component render template."
  },
  "zQuery List Rendering": {
    "prefix": "zq-list",
    "body": [
      "\\${${1:this.state.items}.map(${2:item} => `",
      "\t<${3:div} class=\"${4:item}\">\\${${2}.${5:name}}</${3}>",
      "`).join('')}"
    ],
    "description": "Map over array to render a list in component template."
  },

  "_comment_form": "──── Forms ────",

  "zQuery Form (z-model)": {
    "prefix": "zq-form",
    "body": [
      "<form @submit.prevent=\"${1:handleSubmit}\">",
      "\t<div>",
      "\t\t<label>${2:Name}</label>",
      "\t\t<input z-model=\"${3:name}\" ${4:z-trim} placeholder=\"${5:Enter name}\">",
      "\t</div>",
      "\t<button>${6:Submit}</button>",
      "</form>"
    ],
    "description": "Form template with z-model bindings and submit handler."
  },
  "zQuery Select Element (z-model)": {
    "prefix": "zq-select-el",
    "body": [
      "<select z-model=\"${1:selected}\">",
      "\t<option value=\"${2:opt1}\">${3:Option 1}</option>",
      "\t<option value=\"${4:opt2}\">${5:Option 2}</option>",
      "</select>"
    ],
    "description": "Select element with z-model binding."
  },
  "zQuery Checkbox (z-model)": {
    "prefix": "zq-checkbox",
    "body": [
      "<label>",
      "\t<input z-model=\"${1:checked}\" type=\"checkbox\">",
      "\t${2:Label}",
      "</label>"
    ],
    "description": "Checkbox with z-model boolean binding."
  },

  "_comment_layout": "──── Layout & Navigation ────",

  "zQuery Router Outlet": {
    "prefix": "zq-outlet",
    "body": [
      "<div id=\"${1:app}\"></div>"
    ],
    "description": "Router outlet element."
  },
  "zQuery Nav Links": {
    "prefix": "zq-nav",
    "body": [
      "<nav>",
      "\t<a z-link=\"/\">${1:Home}</a>",
      "\t<a z-link=\"/${2:about}\">${3:About}</a>",
      "\t<a z-link=\"/${4:contact}\">${5:Contact}</a>",
      "</nav>"
    ],
    "description": "Navigation bar with z-link router links."
  },
  "z-key": {
    "prefix": "z-key",
    "body": [
      "z-key=\"{{${1:item.id}}}\""
    ],
    "description": "Keyed reconciliation attribute for z-for loops — enables efficient DOM morphing by matching elements by identity."
  },
  "zQuery Slot (default)": {
    "prefix": "zq-slot",
    "body": [
      "<slot>${1:Fallback content}</slot>"
    ],
    "description": "Default slot for content distribution. Inner content is used as fallback when no content is provided."
  },
  "zQuery Slot (named)": {
    "prefix": "zq-slot-named",
    "body": [
      "<slot name=\"${1:header}\">${2:Default header}</slot>"
    ],
    "description": "Named slot for targeted content distribution. Fill with <template slot='name'>…</template> or slot='name' on a direct child."
  },
  "zQuery For + Key": {
    "prefix": "zq-for-key",
    "body": [
      "<${1:li} z-for=\"${2:item} in ${3:items}\" z-key=\"{{${2:item}.${4:id}}}\">",
      "\t{{${2:item}.${5:name}}}",
      "</${1:li}>"
    ],
    "description": "z-for loop with z-key for keyed DOM reconciliation."
  }
}
